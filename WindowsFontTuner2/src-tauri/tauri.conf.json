{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WindowsFontTuner 2.0",
  "version": "2.2.4",
  "identifier": "com.sober.windowsfonttuner2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WindowsFontTuner 2.0",
        "width": 1500,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
